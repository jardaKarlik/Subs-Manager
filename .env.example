# ============================================================================
# Subscription Manager - Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in your actual credentials
# DO NOT commit the .env file to git (it's in .gitignore)
# ============================================================================

# --- Composio Configuration ---
# Get API key from https://app.composio.dev/settings
COMPOSIO_API_KEY=comp_your_api_key_here

# --- Gmail Configuration (Primary Account) ---
GMAIL_USER_1=your_gmail@gmail.com
GMAIL_API_ENABLED=true

# --- Gmail Configuration (Secondary Account) ---
GMAIL_USER_2=
GMAIL_API_ENABLED_2=false

# --- Outlook / Live.com Configuration ---
# Email: jaroslav.karlik@live.com (or your Outlook account)
OUTLOOK_USER=your_email@live.com
OUTLOOK_USER_2=

# --- IMAP Configuration (Zoner / klikni.org) ---
IMAP_SERVER=imap.zoner.com
IMAP_PORT=993
IMAP_USER=your_email@klikni.org
IMAP_PASSWORD=your_app_password
IMAP_VERIFY_SSL=true

# --- Reddit Configuration (optional) ---
REDDIT_USER=

# --- LinkedIn Configuration (optional) ---
LINKEDIN_USER=

# --- Application Configuration ---
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=sqlite:///./subscriptions.db

# --- API Server Configuration ---
API_HOST=localhost
API_PORT=8000
API_WORKERS=1
